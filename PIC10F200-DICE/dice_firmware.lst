000C   0C07           00044     MOVLW   7
000D   0190           00045     XORWF   face_value, W       ; Compare face_value with 7
000E   0743           00046     BTFSS   STATUS, Z
000F   0A12           00047     GOTO    CHECK_BUTTON        ; If face_value < 7
0010   0C01           00048     MOVLW   1                   ; If face_value = 7
0011   0030           00049     MOVWF   face_value          ; Reset counter to 1
                      00050 
0012                  00051 CHECK_BUTTON:
0012   0766           00052     BTFSS   GPIO, 3             ; Test GP3 state
0013   0A0B           00053     GOTO    DICE_RANDOM_ROLL    ; If GP3 == LOW (Keep rolling)
                      00054 
0014   0CFF           00055     MOVLW   0xFF                ; Loading literals to verification timer
0015   0031           00056     MOVWF   disp_timer_1
                      00057 
                      00058 ; SOFTWARE DEBOUNCING (ignore change in state on GP3 if it is shorter than 10 ms) 
0016                  00059 VERIFY_STABILITY_LOOP:
0016   0C20           00060     MOVLW   0x20                ; Loading sampling frequency
0017   0032           00061     MOVWF   disp_timer_2
                      00062 
0018                  00063 SAMPLE_PIN_LOOP:
0018   0766           00064     BTFSS   GPIO, 3             ; Test GP3 state again
0019   0A0B           00065     GOTO    DICE_RANDOM_ROLL    ; If GP3 == LOW (Bounce detected - Reset)
                      00066 
001A   02F2           00067     DECFSZ  disp_timer_2, F
001B   0A18           00068     GOTO    SAMPLE_PIN_LOOP
                      00069 
001C   02F1           00070     DECFSZ  disp_timer_1, F     ; Decrement main verification timer
001D   0A16           00071     GOTO    VERIFY_STABILITY_LOOP
                      00072 
001E   0A1F           00073     GOTO    START_ANIMATION     ; Button is stable
                      00074 
001F                  00075 START_ANIMATION:
                      00076                                 ; STEP 1: DIAGONAL 1
001F   0C04           00077     MOVLW   B'0100'             ; GP0 = LOW, GP2 == HIGH
0020   0026           00078     MOVWF   GPIO
0021   0C0A           00079     MOVLW   B'1010'             ; Configuring GP2 and GP0 as output
0022   0006           00080     TRIS    GPIO
0023   0949           00081     CALL    ANIM_DELAY          ; Animation display delay
0024   093E           00082     CALL    ANIM_OFF            ; Animation parts separation for visual effect
                      00083 
                      00084                                 ; STEP 2: DIAGONAL 2
0025   0C01           00085     MOVLW   B'0001'             ; GP0 == HIGH, GP2 == LOW
0026   0026           00086     MOVWF   GPIO
0027   0C0A           00087     MOVLW   B'1010'             ; Configuring GP2 and GP0 as output
0028   0006           00088     TRIS    GPIO
0029   0949           00089     CALL    ANIM_DELAY
002A   093E           00090     CALL    ANIM_OFF
                      00091 
                      00092                                 ; STEP 3: CENTER
002B   0C04           00093     MOVLW   B'0100'             ; GP2 == HIGH, GP1 == LOW
002C   0026           00094     MOVWF   GPIO
002D   0C09           00095     MOVLW   B'1001'             ; Configuring GP1 and GP2 as output
002E   0006           00096     TRIS    GPIO
