                      00036 
  00000021            00037 GATEDTIME       EQU     .33             ; time in msec that is used to measure the frequency
                      00038 
  00000005            00039 AVDEPTH         EQU     .5              ; averaging depth
                      00040                                         ;    2 ^ (n-1) x oldvalue + newvalue
                      00041                                         ; = ---------------------------------
                      00042                                         ;               (2 ^ n)
                      00043 
                      00044 ; For Proximity
  00000010            00045 TRIPLO_PRX      EQU     .16             ; difference between average and current
  00000000            00046 TRIPHI_PRX      EQU     .0              ; frequency value for a key to be detected. (512 counts)
