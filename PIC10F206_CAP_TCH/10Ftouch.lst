0000                  00062 RESET
0000   0025           00063         MOVWF   OSCCAL              ; calibrate internal oscillator
                      00064 
                      00065                 ; If waking from intentional sleep, return back to post-sleep command
                      00066                 ; CWUF = 0, GPWUF = 0, TO = 0, PO = 0        STATUS BITS for wake from WDT
                      00067 ;               movf    STATUS, w
                      00068 ;               andlw   b'11111000'                     ; and off ALU status bits to zero
                      00069 ;               btfsc   STATUS, Z                       ; check if all bits are zero, branch accordingly
                      00070 ;               goto    jumpbackaftersleep      ; all zero
                      00071 ;               goto    jumpinit                        ; non-zero
                      00072 
