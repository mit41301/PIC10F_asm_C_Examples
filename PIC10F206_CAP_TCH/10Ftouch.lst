001F   0603           00158         BTFSC   STATUS,C
0020   0A26           00159         GOTO    HOPOVER
0021   00EE           00160         DECF    AVERAGELO
0022   0CFF           00161         MOVLW   .255
0023   018E           00162         XORWF   AVERAGELO,W
0024   0643           00163         BTFSC   STATUS,Z
0025   00ED           00164         DECF    AVERAGEHI           
0026                  00165 HOPOVER
