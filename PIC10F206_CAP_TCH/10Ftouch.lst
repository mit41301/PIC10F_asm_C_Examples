                      00211 ;********************************************************
                      00212 ;* subroutine: checkdifference                          *
                      00213 ;* descr: subtracts actual value from average           *
                      00214 ;*                                                      *
                      00215 ;* out:   freqhi:freqlo  with frequency                 *
                      00216 ;********************************************************
                      00217 ;{
0049                  00218 CHECKDIFFERENCE
0049   020D           00219         MOVF    AVERAGEHI,W
004A   0032           00220         MOVWF   DIFFERENCEHI
004B   020E           00221         MOVF    AVERAGELO,W
004C   0033           00222         MOVWF   DIFFERENCELO    ; make a copy of the averagevalue
                      00223 
004D   020C           00224         MOVF    FREQLO,W
004E   00B3           00225         SUBWF   DIFFERENCELO
004F   0703           00226         BTFSS   STATUS,C
0050   00F2           00227         DECF    DIFFERENCEHI
0051   020B           00228         MOVF    FREQHI,W
0052   00B2           00229         SUBWF   DIFFERENCEHI    ; averagevalue - currentvalue
                      00230 
0053   0603           00231         BTFSC   STATUS,C        ; is the difference negative?
0054   0A5D           00232         GOTO    EVALDIFFERENCE  ; no positive, check if it exceeds the trip point
0055   020B           00233         MOVF    FREQHI,W        ; yes, key is released
0056   002D           00234         MOVWF   AVERAGEHI       ; average should follow actual value
0057   020C           00235         MOVF    FREQLO,W
0058   002E           00236         MOVWF   AVERAGELO
0059   0072           00237         CLRF    DIFFERENCEHI
005A   0073           00238         CLRF    DIFFERENCELO
005B   0415           00239         BCF     USERFLAG,KEYDOWN
                      00240 
005C   0800           00241         RETLW   .0
                      00242 
005D                  00243 EVALDIFFERENCE
005D   0415           00244         BCF     USERFLAG,KEYDOWN
                      00245 
005E   0C01           00246                 MOVLW   TRIPHI_TCH
005F   0666           00247                 BTFSC   GPIO, 3
0060   0C00           00248         MOVLW   TRIPHI_PRX
0061   0092           00249         SUBWF   DIFFERENCEHI,W
0062   0743           00250         BTFSS   STATUS,Z        ; are hi bytes equal?
0063   0A68           00251         GOTO    RESULTS
                      00252 
                      00253 
0064   0C32           00254                 MOVLW   TRIPLO_TCH
0065   0666           00255                 BTFSC   GPIO, 3
0066   0C10           00256         MOVLW   TRIPLO_PRX      ; yes, compare lower bytes
0067   0093           00257         SUBWF   DIFFERENCELO,W
0068                  00258 RESULTS
MPASM  5.15                      10FTOUCH.ASM   5-20-2008  16:12:10         PAGE  7


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00259 
0068   0703           00260         BTFSS   STATUS,C        ; was the difference > trip point?
0069   0800           00261         RETLW   .0              ; no, return
                      00262 
006A   0515           00263         BSF     USERFLAG,KEYDOWN ; yes, set the keydown flag
                      00264 
006B   0800           00265         RETLW   .0
                      00266 ;}
                      00267 ;********************************************************
                      00268 ;* subroutine: getfrequency                             *
                      00269 ;* descr: converts to binary coded decimal              *
                      00270 ;*                                                      *
                      00271 ;* out:   freqhi:freqlo  with frequency                 *
                      00272 ;********************************************************
                      00273 ;{
006C                  00274 GETFREQUENCY
006C   0CF7           00275         MOVLW   B'11110111'
                      00276               ;   ||||||||_ ps0
                      00277               ;   |||||||__ ps1
                      00278               ;   ||||||___ ps2   set prescaler to 1:256
                      00279               ;   |||||____ psa   prescaler assigned to tmr0
                      00280               ;   ||||_____ t0se  increment on high to low
                      00281               ;   |||______ t0cs  transition on t0cki
                      00282               ;   ||_______ #gppu pull-ups disabled
                      00283               ;   |________ #gpwu wake-up on pin change disabled
006D   0002           00284         OPTION
                      00285 
006E   0C0B           00286         MOVLW   B'00001011'
                      00287               ;   ||||||||_ #cwu    wake-up on comp change disabled
                      00288               ;   |||||||__ cpref   pos ref is cin+
                      00289               ;   ||||||___ cnref   neg ref is internal 0.6V reference
                      00290               ;   |||||____ cmpon   comparator on
                      00291               ;   ||||_____ cmpt0cs comparator output used as tmr0 clock
                      00292               ;   |||______ pol     output is inverted
                      00293               ;   ||_______ #couten output is placed on cout pin
                      00294               ;   |________ cmpout  -read only bit-
006F   0027           00295         MOVWF   CMCON0
                      00296         
0070   0CFF           00297         MOVLW   .255            ; frequency will be stored in freqhi:freqlo
0071   002C           00298         MOVWF   FREQLO          ; freqlo is pre-initialised here
                      00299 
0072   0061           00300         CLRF    TMR0            ; clear tmr0 and the 1:256 prescaler
0073   0C21           00301         MOVLW   GATEDTIME
0074   090E           00302         CALL    DELAY           ; wait N mSec for scan time
                      00303 
0075   0467           00304         BCF     CMCON0,CMPON    ; turn off oscillator
                      00305 
0076   0201           00306         MOVF    TMR0,W          ; high byte of value is stored in tmr0
0077   002B           00307         MOVWF   FREQHI          ; low value is still in the prescaler
                      00308 
                      00309 ; To get the value from the prescaler (which is not directly readable),
                      00310 ; the clock source for tmr0 is changed to Fosc/4.
                      00311 ; Next the value of tmr0 is observed. The time is takes for the next
MPASM  5.15                      10FTOUCH.ASM   5-20-2008  16:12:10         PAGE  8


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

                      00312 ; increment is an indication of the value of the prescaler.
                      00313 
0078   0CD7           00314         MOVLW   B'11010111'     ; change clock source to Fosc/4
0079   0002           00315         OPTION
                      00316 
007A                  00317 MEASUREPRESCALER
007A   02AC           00318         INCF    FREQLO          ; was initialised to 255 and set to 0 here
007B   0201           00319         MOVF    TMR0,W          ; get the current value of tmr0
007C   018B           00320         XORWF   FREQHI,W        ; compare it with the original value of tmr0
007D   0643           00321         BTFSC   STATUS,Z        ; did tmr0 increment?
007E   0A7A           00322         GOTO    MEASUREPRESCALER ; no, loop and increment freqlo
                      00323 
                      00324 ; Now freqlo ranges from 0 to 43. The next section will muliply it
                      00325 ; with 6 and clipped to 255, to get the lobyte of the frequency count.
                      00326 
007F   0403           00327         BCF     STATUS,C        ; clear the carry bit
0080   036C           00328         RLF     FREQLO          ; muliply by 2
0081   034C           00329         RLF     FREQLO ,W       ; and muliply by 2 again, but put the result in w
0082   01EC           00330         ADDWF   FREQLO          ; add it to the doubled value (multiplied by 6)
0083   0703           00331         BTFSS   STATUS,C        ; did it overflow (6 x 43 = 258)
0084   0A87           00332         GOTO    NOOVERFLOW      ; no, go on
0085   0CFF           00333         MOVLW   .255            ; yes, clip it to 255
0086   002C           00334         MOVWF   FREQLO 
                      00335 
0087                  00336 NOOVERFLOW
0087   026C           00337         COMF    FREQLO          ; the time for the prescaler to roll over was measured,
                      00338                                 ; so its value was 255 - prescaler value
                      00339 
                      00340 ; Because of the way the prescaler rollover time was measured (6 Tcy in measureprescaler),
                      00341 ; atleast the 2 least significant bits in freqhi:frequlo are useless.
                      00342 ; Therefore the final result is divided by 4.
                      00343 
0088   0403           00344         BCF     STATUS,C
0089   032B           00345         RRF     FREQHI
008A   032C           00346         RRF     FREQLO
008B   0403           00347         BCF     STATUS,C
008C   032B           00348         RRF     FREQHI
008D   032C           00349         RRF     FREQLO          ; divide by 4
                      00350 
                      00351 
008E   0467           00352                 BCF             CMCON0, CMPON   ; turn comp off to conserve power
                      00353 
008F   0800           00354         RETLW   .0              ; done
                      00355 ;}
                      00356 
                      00357 
                      00358 
                      00359 ;********************************************************
                      00360 ;* main                                                 *
                      00361 ;********************************************************
                      00362 ;{
0090                  00363 MAIN
0090   0C21           00364         MOVLW   GATEDTIME
MPASM  5.15                      10FTOUCH.ASM   5-20-2008  16:12:10         PAGE  9


