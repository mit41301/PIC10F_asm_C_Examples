                      00081 ;********************************************************
                      00082 ;* subroutine init                                      *
                      00083 ;********************************************************
                      00084 ;{
0003                  00085 INIT    
0003   0CF7           00086         MOVLW   B'11110111'
                      00087               ;   ||||||||_ ps0
                      00088               ;   |||||||__ ps1
                      00089               ;   ||||||___ ps2   set prescaler to 1:256
                      00090               ;   |||||____ psa   prescaler assigned to tmr0
                      00091               ;   ||||_____ t0se  increment on high to low
                      00092               ;   |||______ t0cs  transition on t0cki
                      00093               ;   ||_______ #gppu pull-ups disabled
                      00094               ;   |________ #gpwu wake-up on pin change disabled
0004   0002           00095         OPTION
                      00096 
0005   0C0B           00097         MOVLW   B'00001011'
                      00098               ;   ||||||||_ #cwu    wake-up on comp change disabled
                      00099               ;   |||||||__ cpref   pos ref is cin+
                      00100               ;   ||||||___ cnref   neg ref is internal 0.6V reference
