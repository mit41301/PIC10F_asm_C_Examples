00A8                  00425 FINISH_LOOP:    
                      00426                 ; Sleep
                      00427  ;              movlw   b'11111011'                             ; Prescalar on 1:8 WDT, assign to WDT
                      00428  ;      option
                      00429  ;              movlw   .1
                      00430  ;              call    delay                                   ; delay for 1 ms to ensure comparator of
                            f, everything settled before sleep
                      00431  ;              sleep                                                   ; goto sleep for ~144ms (8*18ms)
                      00432  ;              nop                                                             ; don't pre-fetch anythi
                            ng unintended after sleep instruction
                      00433  ;      Sleep Code Commented out
                      00434                 
