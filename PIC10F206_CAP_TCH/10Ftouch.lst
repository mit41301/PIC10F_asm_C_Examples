  00000001            00044 OUTPUT                  EQU .1
                      00045 
                      00046 ; bit definitions in userflag
  00000000            00047 KEYDOWN                 EQU .0
  00000001            00048 LOCKAVG                 EQU .1      ; lock the averaging mechanism during continuous touch
  00000003            00049 SLEEPING                EQU     .3              ; for use in going to and waking from sleep
  00000004            00050 ONESHOTDONE             EQU .4          ; for use in seeing if one shot trigger output has happened - se
