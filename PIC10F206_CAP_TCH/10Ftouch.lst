                      00120 ;********************************************************
                      00121 ;* subroutine delay                                     *
                      00122 ;* descr: causes a timing delay in mSecs                *
                      00123 ;*                                                      *
                      00124 ;* in:    w - value in mSecs                            *
                      00125 ;********************************************************
                      00126 ;{
000E                  00127 DELAY
000E   0028           00128         MOVWF   TEMP1
000F                  00129 WAIT
000F   0CF9           00130         MOVLW   .249
0010   0029           00131         MOVWF   TEMP2
0011   0004           00132            CLRWDT                               ; instead of nop, use clrwdt to clrwdt while awake
0012   02E9           00133            DECFSZ  TEMP2                ; all other code is much much less than 18ms (WDT timeout) when 
                            not delaying
0013   0A11           00134            GOTO    $-2
                      00135 
0014   02E8           00136         DECFSZ  TEMP1
0015   0A0F           00137         GOTO    WAIT
0016   0800           00138         RETLW   .0
                      00139 ;}
                      00140 ;********************************************************
