0091   090E           00365         CALL    DELAY           ; wait 30mSec
                      00366 
0092   0C31           00367         MOVLW   .49
0093   0033           00368         MOVWF   DIFFERENCELO
0094   0C01           00369         MOVLW   .1
0095   0032           00370         MOVWF   DIFFERENCEHI
0096   095D           00371         CALL    EVALDIFFERENCE
                      00372         
0097   0000           00373         NOP
                      00374 
0098   096C           00375         CALL    GETFREQUENCY
0099   020B           00376         MOVF    FREQHI,W
009A   002D           00377         MOVWF   AVERAGEHI
009B   020C           00378         MOVF    FREQLO,W
009C   002E           00379         MOVWF   AVERAGELO
                      00380 
                      00381 
009D                  00382 MAINLOOP
                      00383                 ; Sensing and Detection
009D   096C           00384         CALL    GETFREQUENCY
009E   0917           00385         CALL    AVERAGE
009F   0949           00386         CALL    CHECKDIFFERENCE
                      00387 
                      00388                 ; Check if Key Was Pressed
00A0   0615           00389                 BTFSC   USERFLAG, KEYDOWN
00A1   0AA4           00390                 GOTO    REACT_KEYDOWN
00A2   0715           00391                 BTFSS   USERFLAG, KEYDOWN
00A3   0AA6           00392                 GOTO    REACT_KEYUP
                      00393 
                      00394                 ; If a press was detected, output low (LED ON) else output high (LED OFF)
