0001   0C01           00098         movlw 1 ; init the constant
0002   0030           00099         movwf ONE
                      00100 
                      00101         ; prescaler max, assigned to TMR0
                      00102         ; no pull-up or wake up
0003   0CC7           00103         movlw 0xC7 ; 1100 0 111
0004   0002           00104         option
                      00105 
                      00106         ; short wait
0005   0926           00107         call espace
0006   0926           00108         call espace
                      00109 
0007                  00110 rebouclage:
0007   0075           00111         clrf index;
                      00112 
0008                  00113 endless:
0008   093A           00114         call texte ; read the next char.
0009   0033           00115         movwf reg ; save the char
000A   02B5           00116         incf index,f ; increment the char counter
                      00117 
                      00118 ; structure of the 3 LSB in reg :
                      00119 ; 0 : space between words
                      00120 ; 1-5 : 5 bits to decode, in MSB
                      00121 ; 6,7 : not used
                      00122 
                      00123 ;************** check if space : **************
000B   0233           00124         movf reg, f
000C   0743           00125         btfss STATUS, Z
000D   0A13           00126         goto nospace
                      00127 
                      00128 ; space between words :
                      00129 ;       movlw 5-1 ; 1 tic already done
                      00130 ;       call wait
000E   0926           00131         call espace
000F   0926           00132         call espace
0010   0926           00133         call espace
0011   0926           00134         call espace
                      00135 
0012   0A08           00136         goto endless
                      00137 
                      00138 ;************** decode the letters: **************
0013                  00139 nospace:
                      00140 
                      00141 ; copy the 3LSB of reg into len (counter of tics)
0013   0213           00142         movfw reg
0014   0E07           00143         andlw 7
0015   0034           00144         movwf len
                      00145 
                      00146 ; preshift MSB
0016   0333           00147         rrf reg, f
0017   0333           00148         rrf reg, f
0018   0333           00149         rrf reg, f
                      00150 
