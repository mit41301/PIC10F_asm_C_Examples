0019                  00151 loop_tic:
                      00152 ; LED ON
0019   0CFD           00153           movlw MORSE_ON
001A   0006           00154           tris GPIO
                      00155 
                      00156 ; decode : dash or dot ?
001B   0C01           00157           movlw 1 ; default : dot = 1 tic
001C   0333           00158           rrf reg, f ; get a new bit
001D   0603           00159           btfsc STATUS, C ; if it's a dot, keep the default tic count
001E   0F02           00160           xorlw 2 ; 3 tics if dash
001F   092D           00161           call wait
                      00162 
                      00163 ; space between two tics:
0020   0926           00164           call espace
                      00165 
                      00166 ; reloop
0021   02F4           00167         decfsz len, f
0022   0A19           00168         goto loop_tic
                      00169 
                      00170 ; space between 2 letters :
                      00171 ;        movlw 3-1 ; 1 tic already done
                      00172 ;        call wait
0023   0926           00173         call espace
0024   0926           00174         call espace
                      00175 
0025   0A08           00176         goto endless
                      00177 
                      00178 
                      00179 #define ratio (2<<4) ; hint : cf swapf for sub-unit wait
0026                  00180 espace:
                      00181 ; turn off
0026   0CFF           00182         movlw MORSE_OFF
0027   0006           00183         tris GPIO
                      00184 
                      00185         ; relic from a different version
0028   0C20           00186         movlw ratio
0029   092D           00187         call wait
002A   0CE0           00188         movlw 256-ratio
002B   092D           00189         call wait
                      00190 
                      00191 ;mit4301        return
002C   0800           00192                 RETLW 0
                      00193 
                      00194 ;--------------------------------------------
                      00195 ;  wait for a given number of tics in W
                      00196 ;--------------------------------------------
                      00197 
002D   0032           00198 wait:   movwf cpt2
002E   03B2           00199         swapf cpt2,f ; x16
                      00200 
002F   0CC8           00201 wait1:  movlw 200 ; 1 tic
0030   0031           00202         movwf cpt1
                      00203 
